# Production build only — asset base (must match STOREFRONT_ASSET_BASE in Laravel .env)
# Dev server (npm run dev) always uses "/" — do not need to change this for local preview
VITE_STOREFRONT_BASE=/vellor/public/website/

# Laravel API — leave EMPTY when running `npm run build` for live (auto-detected from /s/{slug} URL).
# Set only for local `npm run dev` if not using the Vite /api proxy:
# VITE_API_BASE=http://localhost/vellor/public
VITE_API_BASE=

# Vite dev proxy target
VITE_API_PROXY_TARGET=http://localhost/vellor/public

# Fallback slug when opening Vite dev without /s/{slug} in path
VITE_DEFAULT_SALON_SLUG=ak-salon

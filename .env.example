APP_NAME=EasyGrox
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

# React salon website — dev preview URL (Go Live opens this when set)
# SALON_WEBSITE_DEV_URL=http://localhost:5173
# STOREFRONT_ASSET_BASE=/vellor/website/

# Subscriptions: set true to enable Stripe billing UI, plan limits, and feature gates.
SUBSCRIPTIONS_ENABLED=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Login rate limit (attempts per minute per IP)
RATE_LIMIT_AUTH=10

# Cloudflare Turnstile (login page CAPTCHA)
# https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Security headers + HTTPS (production)
# Set APP_URL=https://your-domain.com and SESSION_SECURE_COOKIE=true on live
SESSION_SECURE_COOKIE=false
HSTS_ENABLED=true
CSP_ENABLED=true
CSP_REPORT_ONLY=false

# Cloudflare WAF: configure in Cloudflare dashboard (SSL/TLS Full, Bot Fight Mode, OWASP ruleset)

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Redirect legacy /public/ URLs to clean paths (e.g. /vellor/public/login → /vellor/login)
    RewriteCond %{THE_REQUEST} \s/+(.*/)?public/([^\s?]*) [NC]
    RewriteRule ^ /%1%2 [R=301,L,NE]

    # Route all requests through Laravel's public directory
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
